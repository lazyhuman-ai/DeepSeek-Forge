{
  "name": "forgeagent",
  "version": "0.1.0",
  "license": "MIT",
  "description": "DeepSeek-native local AI agent workspace for Mac, Chrome, Android, MCP, browser automation, and private multi-device workflows.",
  "keywords": [
    "deepseek",
    "deepseek-agent",
    "ai-agent",
    "agent-harness",
    "local-first",
    "mcp",
    "browser-agent",
    "chrome-automation",
    "coding-agent",
    "web-console",
    "android",
    "macos"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "ui:typecheck": "tsc -p web/tsconfig.json --noEmit",
    "ui:build": "vite build --config web/vite.config.ts",
    "ui:e2e": "playwright test",
    "product:build": "npm run ui:typecheck && npm run ui:build",
    "macos:build": "swift build --package-path apps/macos/ForgeAgentMac",
    "macos:package": "bash apps/macos/ForgeAgentMac/scripts/package_app.sh",
    "macos:smoke": "node scripts/macos-package-and-smoke.mjs",
    "macos:run": "swift run --package-path apps/macos/ForgeAgentMac ForgeAgentMac",
    "android:build": "node scripts/android-build.mjs",
    "android:lint": "node scripts/android-build.mjs lintDebug",
    "android:test": "node scripts/android-build.mjs testDebugUnitTest",
    "android:install": "node scripts/android-build.mjs installDebug",
    "native:build": "npm run macos:smoke && npm run android:build && npm run android:test",
    "check": "npm run typecheck && npm run product:build && npm test && npm run ui:e2e",
    "forgeagent": "tsx src/cli/forgeagent.ts",
    "install:local": "npm run product:build && tsx src/cli/forgeagent.ts install",
    "install-service": "tsx src/cli/forgeagent.ts install-service",
    "uninstall-service": "tsx src/cli/forgeagent.ts uninstall-service",
    "doctor": "tsx src/cli/forgeagent.ts doctor",
    "extensions": "tsx src/cli/extensions.ts",
    "skills": "tsx src/cli/skills.ts",
    "mcp": "tsx src/cli/mcp.ts",
    "logs": "tsx src/cli/forgeagent.ts logs",
    "webridge:package": "tsx src/cli/forgeagent.ts webridge-package",
    "webridge:open": "tsx src/cli/forgeagent.ts webridge-open",
    "start": "tsx src/cli/forgeagent.ts start",
    "status": "tsx src/cli/forgeagent.ts status",
    "stop": "tsx src/cli/forgeagent.ts stop",
    "http": "tsx src/gateways/http/main.ts",
    "repl": "tsx src/gateways/repl/main.ts",
    "pair": "tsx src/gateways/http/pair.ts",
    "soak:complex": "tsx scripts/soak-complex.ts",
    "soak:browser": "tsx scripts/soak-browser-runtime.ts",
    "soak:real": "tsx scripts/soak-real.ts",
    "soak:resilience": "tsx scripts/soak-resilience.ts",
    "release:e2e": "tsx scripts/release-e2e.ts",
    "coding:e2e": "env RELEASE_E2E_SCENARIOS=agent_coding_workspace,agent_implementation_subagent,agent_background_subagents,agent_subagent_worktree_merge,agent_python_code_index,agent_persistent_multilanguage_lsp,agent_lsp_unavailable_recovery,agent_notebook_edit,agent_artifact_continuation,agent_multifile_refactor,agent_frontend_workspace,agent_package_install_permission,agent_dynamic_skill_use,agent_destructive_command_denied,agent_compaction_coding_continuity,agent_restart_coding_continuity,ui_review_work_activity tsx scripts/release-e2e.ts",
    "coding:parity": "tsx scripts/coding-parity.ts",
    "extensions:e2e": "tsx scripts/extension-e2e.ts",
    "release:gate": "npm run check && npm run coding:parity && npm run native:build && npm run extensions:e2e && npm run release:e2e",
    "release:bundle": "npm run native:build && npm run forgeagent -- webridge-package --output-dir .forge-release/dist && node scripts/package-release.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "pyright": "^1.1.410",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  }
}
