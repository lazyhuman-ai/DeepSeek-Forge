# Optional developer fallback. The Web Console provider setup is the recommended user path.
API_KEY=
DEEPSEEK_API_KEY=
BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
CONTEXT_WINDOW_TOKENS=1000000

# Local gateway
FORGE_DATA_DIR=.forge
HTTP_HOST=127.0.0.1
HTTP_PORT=3000

# Optional Chrome CDP runtime. ForgeWebridge is the default browser path.
# FORGE_BROWSER_CDP_URL=http://127.0.0.1:9222
# FORGE_BROWSER_RUNTIME_NAME=chrome

# Optional local voice input. ForgeAgent first uses the local GGML quantized Belle model
# under ~/Library/Application Support/ForgeAgent/models when it exists, otherwise it
# falls back to local python + mlx_whisper.
# FORGE_WHISPER_MODEL=/Users/you/Library/Application Support/ForgeAgent/models/belle-whisper-large-v3-turbo-zh-ggml-q5_0/ggml-belle-large-v3-turbo-zh-q5_0.bin
# FORGE_VOICE_LANGUAGE=zh
# FORGE_VOICE_TIMEOUT_MS=120000
# FORGE_VOICE_MAX_BODY_BYTES=26214400
# FORGE_VOICE_TRANSCRIBE_COMMAND=/path/to/whisper-cli
# FORGE_VOICE_TRANSCRIBE_ARGS=["-m","/path/to/model.bin","-f","{audio}","-l","{language}"]

# Optional ForgeWebridge tuning
# FORGE_WEBRIDGE_ENABLED=1
# FORGE_WEBRIDGE_RUNTIME_NAME=webridge
